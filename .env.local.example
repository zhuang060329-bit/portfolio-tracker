# 複製本檔為 .env.local 後填入實際金鑰（.env.local 已被 .gitignore 忽略，不會進版控）。
# master prompt 第 7 節。值都先留空，由使用者自行填。
# 注意：真實金鑰只填到 .env.local，不要填在本範本檔（本檔會進版控）。

# Supabase（新版金鑰）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=   # sb_publishable_...（前端用）
SUPABASE_SECRET_KEY=                    # sb_secret_...（只在伺服器端 / cron 用）

# 價格資料來源
TWELVE_DATA_API_KEY=                    # 美股 + USD/TWD 匯率
FINMIND_TOKEN=                          # 台股
COINGECKO_DEMO_KEY=                     # 加密貨幣

# 保護 Vercel Cron 抓價路由用的隨機字串
CRON_SECRET=

# Sentry（選用；不填則完全 no-op）。前後端各一條。
# 在 sentry.io 建專案後，DSN 從 Project Settings → Client Keys 取得。
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
